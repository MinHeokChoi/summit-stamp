{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiker.invalid/evidence/schemas/runtime-evidence/v1",
  "title": "Hiker runtime evidence v1",
  "description": "A redacted runtime gate record. The schema permits only opaque identifiers, digests, timestamps, and coded outcomes; it has no fields for credentials, tokens, network endpoints, or personal data.",
  "type": "object",
  "required": [
    "schemaVersion",
    "artifactType",
    "id",
    "status",
    "collectedAt",
    "gitSHA",
    "output",
    "inputHashes",
    "checks"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "artifactType": { "const": "runtime-evidence" },
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$",
      "maxLength": 64
    },
    "status": { "enum": ["passed", "failed", "blocked"] },
    "collectedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "maxLength": 32
    },
    "gitSHA": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "output": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^Evidence/runtime/[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+\\.json$",
          "maxLength": 128
        }
      }
    },
    "inputHashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9]*SHA256$": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["code", "outcome", "evidenceSHA256"],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
          },
          "outcome": { "enum": ["passed", "failed", "blocked"] },
          "evidenceSHA256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "correlation": {
      "type": "object",
      "required": ["runId", "buildDigest"],
      "additionalProperties": false,
      "properties": {
        "runId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
        },
        "buildDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
