{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiker.invalid/evidence/schemas/test-evidence/v1",
  "title": "Hiker test evidence v1",
  "description": "A redacted, machine-verifiable result for a local or CI test command. Raw logs, credentials, and person-identifying fields are intentionally excluded.",
  "oneOf": [
    { "$ref": "#/$defs/commandEvidence" },
    { "$ref": "#/$defs/bijectionNegativeEvidence" },
    { "$ref": "#/$defs/uiBuildProducerEvidence" }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$",
      "maxLength": 64
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "gitSHA": {
      "oneOf": [
        { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        { "const": "uncommitted" }
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$",
      "maxLength": 32
    },
    "safePath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]*(?:/[A-Za-z0-9][A-Za-z0-9._+-]*)*$",
      "maxLength": 512
    },
    "commandToken": {
      "type": "string",
      "allOf": [
        { "pattern": "^[A-Za-z0-9._/:=,+% -]+$" },
        { "not": { "pattern": "(?:^|[=:])/" } }
      ],
      "minLength": 1,
      "maxLength": 256
    },
    "commandEvidence": {
      "type": "object",
      "required": [
        "schemaVersion",
        "id",
        "status",
        "runner",
        "command",
        "exitCode",
        "gitSHA",
        "logSHA",
        "timestamps",
        "output",
        "skippedTests",
        "warnings"
      ],
      "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": 1 },
        "id": { "$ref": "#/$defs/id" },
        "status": { "const": "passed" },
        "runner": {
          "enum": ["swift", "xcode", "xctest", "pgtap"]
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/commandToken" }
        },
        "exitCode": { "const": 0 },
        "gitSHA": { "$ref": "#/$defs/gitSHA" },
        "logSHA": { "$ref": "#/$defs/sha256" },
        "timestamps": {
          "type": "object",
          "required": ["startedAt", "finishedAt"],
          "additionalProperties": false,
          "properties": {
            "startedAt": { "$ref": "#/$defs/timestamp" },
            "finishedAt": { "$ref": "#/$defs/timestamp" }
          }
        },
        "output": {
          "type": "object",
          "required": ["path"],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
              "pattern": "^Evidence/tests/[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+\\.json$",
              "maxLength": 128
            }
          }
        },
        "skippedTests": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 }
      }
    },
    "fixtureResult": {
      "type": "object",
      "required": ["fixture", "kind", "classification", "exitCode", "evidenceTreeBefore", "evidenceTreeAfter"],
      "additionalProperties": false,
      "properties": {
        "fixture": {
          "type": "string",
          "pattern": "^Docs/evidence/fixtures/(?:bijection-valid\\.json|bijection-invalid/[A-Za-z0-9][A-Za-z0-9._-]*\\.json)$",
          "maxLength": 256
        },
        "kind": { "enum": ["valid", "invalid"] },
        "classification": {
          "enum": [
            "success",
            "wrong_destination",
            "wrong_scheme",
            "missing_producer_dependency",
            "undeclared_output",
            "duplicate_id",
            "missing_profile"
          ]
        },
        "exitCode": { "type": "integer", "minimum": 0 },
        "evidenceTreeBefore": { "$ref": "#/$defs/sha256" },
        "evidenceTreeAfter": { "$ref": "#/$defs/sha256" }
      },
      "oneOf": [
        {
          "properties": {
            "kind": { "const": "valid" },
            "classification": { "const": "success" },
            "exitCode": { "const": 0 }
          }
        },
        {
          "properties": {
            "kind": { "const": "invalid" },
            "classification": {
              "enum": [
                "wrong_destination",
                "wrong_scheme",
                "missing_producer_dependency",
                "undeclared_output",
                "duplicate_id",
                "missing_profile"
              ]
            },
            "exitCode": { "type": "integer", "minimum": 1 }
          }
        }
      ]
    },
    "bijectionNegativeEvidence": {
      "type": "object",
      "required": [
        "schemaVersion",
        "id",
        "status",
        "command",
        "exitCode",
        "gitSHA",
        "startedAt",
        "finishedAt",
        "output",
        "evidenceTreeBefore",
        "evidenceTreeAfterValidation",
        "fixtures"
      ],
      "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": 1 },
        "id": { "const": "EVIDENCE-BIJECTION-NEGATIVE" },
        "status": { "const": "passed" },
        "command": { "const": "test-evidence-bijection-negative.sh" },
        "exitCode": { "const": 0 },
        "gitSHA": { "$ref": "#/$defs/gitSHA" },
        "startedAt": { "$ref": "#/$defs/timestamp" },
        "finishedAt": { "$ref": "#/$defs/timestamp" },
        "output": { "const": "Evidence/tests/EVIDENCE-BIJECTION-NEGATIVE.json" },
        "evidenceTreeBefore": { "$ref": "#/$defs/sha256" },
        "evidenceTreeAfterValidation": { "$ref": "#/$defs/sha256" },
        "fixtures": {
          "type": "array",
          "minItems": 7,
          "items": { "$ref": "#/$defs/fixtureResult" },
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": {
                  "kind": { "const": "valid" },
                  "classification": { "const": "success" }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "kind": { "const": "invalid" },
                  "classification": { "const": "wrong_destination" }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "kind": { "const": "invalid" },
                  "classification": { "const": "wrong_scheme" }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "kind": { "const": "invalid" },
                  "classification": { "const": "missing_producer_dependency" }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "kind": { "const": "invalid" },
                  "classification": { "const": "undeclared_output" }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "kind": { "const": "invalid" },
                  "classification": { "const": "duplicate_id" }
                }
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {
                  "kind": { "const": "invalid" },
                  "classification": { "const": "missing_profile" }
                }
              }
            }
          ]
        }
      }
    },
    "uiBuildProducerEvidence": {
      "type": "object",
      "required": [
        "schemaVersion",
        "id",
        "status",
        "runner",
        "command",
        "exitCode",
        "gitSHA",
        "log",
        "manifest",
        "result",
        "timestamps",
        "output",
        "warningSummary"
      ],
      "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": 1 },
        "id": { "const": "UI-BUILD-PRODUCER" },
        "status": { "const": "passed" },
        "runner": { "const": "ui-build" },
        "command": {
          "type": "array",
          "minItems": 17,
          "maxItems": 17,
          "prefixItems": [
            { "const": "xcodebuild" },
            { "const": "clean" },
            { "const": "build-for-testing" },
            { "const": "-workspace" },
            { "const": "Hiker.xcworkspace" },
            { "const": "-scheme" },
            { "const": "HikerUITests" },
            { "const": "-configuration" },
            { "const": "Release" },
            { "const": "-destination" },
            {
              "allOf": [
                { "$ref": "#/$defs/commandToken" },
                { "not": { "pattern": "/" } }
              ]
            },
            { "const": "-derivedDataPath" },
            { "const": ".ci/xctest/DerivedData" },
            { "const": "-resultBundlePath" },
            { "const": ".ci/results/ui-build.xcresult" },
            { "const": "SWIFT_TREAT_WARNINGS_AS_ERRORS=YES" },
            { "const": "GCC_TREAT_WARNINGS_AS_ERRORS=YES" }
          ],
          "items": false
        },
        "exitCode": { "const": 0 },
        "gitSHA": { "$ref": "#/$defs/gitSHA" },
        "log": {
          "type": "object",
          "required": ["path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "path": { "const": ".ci/logs/UI-BUILD-PRODUCER.log" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "manifest": {
          "type": "object",
          "required": ["path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "path": { "const": ".ci/xctest/manifest.json" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "result": {
          "type": "object",
          "required": ["path", "sha256"],
          "additionalProperties": false,
          "properties": {
            "path": { "const": ".ci/results/ui-build.xcresult" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "timestamps": {
          "type": "object",
          "required": ["startedAt", "finishedAt"],
          "additionalProperties": false,
          "properties": {
            "startedAt": { "$ref": "#/$defs/timestamp" },
            "finishedAt": { "$ref": "#/$defs/timestamp" }
          }
        },
        "output": {
          "type": "object",
          "required": ["path"],
          "additionalProperties": false,
          "properties": {
            "path": { "const": "Evidence/tests/UI-BUILD-PRODUCER.json" }
          }
        },
        "warningSummary": {
          "type": "object",
          "required": ["compilerOrTestWarnings", "skippedTests", "nonTestToolWarnings"],
          "additionalProperties": false,
          "properties": {
            "compilerOrTestWarnings": { "const": 0 },
            "skippedTests": { "const": 0 },
            "nonTestToolWarnings": {
              "type": "object",
              "required": ["xcodeNoAppIntentsMetadata"],
              "additionalProperties": false,
              "properties": {
                "xcodeNoAppIntentsMetadata": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    }
  }
}
