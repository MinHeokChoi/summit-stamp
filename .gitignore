# Xcode and SwiftPM build products
DerivedData/
.build/
.swiftpm/
xcuserdata/
*.xcuserstate

# CI workspaces and generated evidence. Keep checked-in source fixtures under
# Docs/evidence/ tracked.
.ci/
Evidence/runtime/
Evidence/tests/
Evidence/manifests/
